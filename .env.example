# Database
DATABASE_URL=postgresql://importacao:importacao123@localhost:5432/importacao
POSTGRES_USER=importacao
POSTGRES_PASSWORD=importacao123
POSTGRES_DB=importacao

# JWT
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRES_IN=24h

# API
API_PORT=3001
NODE_ENV=development

# OpenRouter (AI)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Google Drive
GOOGLE_DRIVE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY=your-private-key
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-root-folder-id

# Google Chat Webhook
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXXX/messages?key=XXXXX&token=XXXXX

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM='"Importação" <your-email@gmail.com>'
SMTP_SECURE=false

# Recipient Emails
KIOM_EMAIL=kiom@example.com
FENICIA_EMAIL=fenicia@example.com
ISA_EMAIL=isa@example.com

# Odoo
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your-odoo-db
ODOO_USER=your-odoo-user
ODOO_PASSWORD=your-odoo-password

# Gmail API (Shared Mailbox via Service Account - preferred method)
# Uses the same service account as Google Drive (GOOGLE_DRIVE_CLIENT_EMAIL/PRIVATE_KEY)
# Requires domain-wide delegation with scope: https://www.googleapis.com/auth/gmail.modify
GMAIL_SHARED_MAILBOX=shared-mailbox@your-domain.com

# IMAP (Email Reading - fallback if Gmail API not configured)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASS=your-app-password
EMAIL_INGESTION_ENABLED=true
EMAIL_ALLOWED_SENDERS=kiom.com.br

# Logging
LOG_LEVEL=info

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
ALLOWED_DOMAIN=your-domain.com

# Google Groups (controle de acesso - só membros do grupo podem logar)
# Email de um admin do Workspace para domain-wide delegation
GOOGLE_ADMIN_EMAIL=admin@your-domain.com
# Google Group cujos membros têm acesso ao sistema
GOOGLE_GROUP_ALLOWED=importacao@your-domain.com

# Cert-API: ERP SQL Server (armazenar no Vault, nunca no código)
ERP_MSSQL_USER=your-erp-user
ERP_MSSQL_PASS=your-erp-password
CERT_API_KEY=your-cert-api-key

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Frontend
# Leave empty for dev (Vite proxy handles /api -> localhost:3001)
# Set to /api for Docker production build
VITE_API_URL=
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
