# =============================================================================
# .env.sops.yaml.example — Template for SOPS-encrypted environment secrets
# =============================================================================
# INSTRUCTIONS:
#   1. cp .env.sops.yaml.example .env.sops.yaml
#   2. Fill in all values
#   3. Encrypt: sops --encrypt --in-place .env.sops.yaml
#   4. Commit .env.sops.yaml (encrypted) and .sops.yaml
#   5. Decrypt to .env: bash scripts/generate-env-from-vault.sh --sops
#
# NEVER commit .env or unencrypted .env.sops.yaml
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER: importacao
POSTGRES_PASSWORD: CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB: importacao

# --- API ---
JWT_SECRET: CHANGE_ME_MINIMUM_32_CHARS_RANDOM
JWT_EXPIRES_IN: 24h
NODE_ENV: production
LOG_LEVEL: info

# --- Google / AI ---
OPENROUTER_API_KEY: ""
OPENROUTER_BASE_URL: https://openrouter.ai/api/v1
GOOGLE_DRIVE_CLIENT_EMAIL: ""
GOOGLE_DRIVE_PRIVATE_KEY: ""
GOOGLE_DRIVE_ROOT_FOLDER_ID: ""
GOOGLE_CHAT_WEBHOOK_URL: ""
GOOGLE_CLIENT_ID: ""
GOOGLE_ADMIN_EMAIL: ""
GOOGLE_GROUP_ALLOWED: ""
GOOGLE_SHEETS_SPREADSHEET_ID: ""

# --- SMTP ---
SMTP_HOST: mta.imgnet.com.br
SMTP_PORT: 2525
SMTP_USER: ""
SMTP_PASS: ""
SMTP_FROM: global@grupounico.com
SMTP_SECURE: "false"

# --- Gmail ingestion ---
GMAIL_SHARED_MAILBOX: ""
EMAIL_INGESTION_ENABLED: "false"
EMAIL_ALLOWED_SENDERS: ""

# --- Frontend ---
VITE_API_URL: ""
VITE_GOOGLE_CLIENT_ID: ""

# --- App config ---
ALLOWED_DOMAIN: grupounico.com
CORS_ORIGIN: ""

# --- Odoo ---
ODOO_URL: ""
ODOO_DB: ""
ODOO_USER: ""
ODOO_PASSWORD: ""

# --- WMS / ERP ---
WMS_ORACLE_HOST: 192.168.168.10
WMS_ORACLE_PORT: "1521"
WMS_ORACLE_SID: WMS
WMS_ORACLE_USER: wisweb
WMS_ORACLE_PASS: CHANGE_ME
ERP_PUKET_HOST: db01.grupounico.com
ERP_PUKET_DB: DB_puket
ERP_IMG_HOST: db02.grupounico.com
ERP_IMG_DB: Grupo_Imaginarium
