{
  "name": "importacao-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=../../.env tsx watch -r dotenv/config src/server.ts",
    "build": "tsc",
    "start": "node --env-file=../../.env dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=../../.env --import tsx src/shared/database/migrate.ts",
    "db:seed": "node --env-file=../../.env --import tsx src/shared/database/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@googleapis/drive": "^8.0.0",
    "@googleapis/gmail": "^16.1.1",
    "@googleapis/sheets": "^13.0.1",
    "@sentry/node": "^10.47.0",
    "@sentry/profiling-node": "^10.47.0",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.36.0",
    "express": "^4.21.0",
    "file-type": "^21.3.2",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "imapflow": "^1.2.10",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.3",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.0",
    "pdf-parse": "^1.1.1",
    "pg-boss": "^10.4.2",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "postgres": "^3.4.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xmlrpc": "^1.3.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.13.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.16",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^7.2.0",
    "@types/xmlrpc": "^1.3.2",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.28.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
